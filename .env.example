# Config app
APP_PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Config database
POSTGRES_HOST=localhost
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nest-base
POSTGRES_SSL=false

# Frontend 
FRONTEND_URL=http://localhost:5173

# Better Auth
BETTER_AUTH_BASE_URL=http://localhost:3000/api/auth
BETTER_AUTH_SECRET=

# OpenSearch Stack Config
KAFKA_HOST=localhost
KAFKA_PORT=9092
KAFKA_CLIENT_ID=nest-base
KAFKA_UI_PORT=8088
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_PROTOCOL=http
DASHBOARDS_PORT=5601

# OpenSearch Security
OPENSEARCH_ADMIN_USER=admin
OPENSEARCH_ADMIN_PASSWORD=complex_Password_123!

# Auth SSO
GOOGLE_CLIENT_ID=your_google_id
GOOGLE_CLIENT_SECRET=your_google_secret

# Apple
APPLE_CLIENT_ID=your_apple_client_id
APPLE_CLIENT_SECRET=your_apple_client_secret
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY="your_apple_private_key_content"

# Config Redis
REDIS_URL=redis://:password@localhost:6379

# Config Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=abcd@gmail.com
MAIL_PASS="abcd dsfs fdsf"
MAIL_FROM="Nest Base <noreply@example.com>"
MAIL_SECURE=false

# Default Admin Account
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=admin1234

# S3 Storage (SeaweedFS)
SEAWEEDFS_VOLUME_PORT=8080
SEAWEEDFS_FILER_PORT=8888
SEAWEEDFS_FILER_S3_PORT=8333
S3_ENDPOINT=http://localhost:8333
S3_PUBLIC_URL=http://localhost:8888/buckets/medias
S3_REGION=us-east-1
S3_ACCESS_KEY=admin
S3_SECRET_KEY=admin
S3_BUCKET=medias
S3_FORCE_PATH_STYLE=true